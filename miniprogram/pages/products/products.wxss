.products-page {
  padding-left: 0;
  padding-right: 0;
}

.products-head {
  padding: 10rpx 24rpx 24rpx;
}

.brand-kicker {
  margin-bottom: 8rpx;
  color: #31543c;
  font-size: 24rpx;
  font-weight: 800;
}

.order-shell {
  display: grid;
  grid-template-columns: 150rpx minmax(0, 1fr);
  min-height: calc(100vh - 210rpx);
  border-top: 1rpx solid rgba(17, 17, 17, 0.05);
  background: #ffffff;
}

.category-rail {
  background: #f1f3ef;
}

.category-tab {
  position: relative;
  min-height: 96rpx;
  padding: 24rpx 18rpx;
  box-sizing: border-box;
  color: #686e66;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.25;
}

.category-tab.active {
  background: #ffffff;
  color: #111111;
  font-weight: 900;
}

.category-tab.active::before {
  position: absolute;
  top: 28rpx;
  bottom: 28rpx;
  left: 0;
  width: 6rpx;
  border-radius: 6rpx;
  background: #d9b073;
  content: "";
}

.product-feed {
  padding: 22rpx 24rpx 40rpx;
}

.feed-banner {
  margin-bottom: 22rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #f6efe3;
}

.feed-title {
  color: #111111;
  font-size: 30rpx;
  font-weight: 900;
}

.feed-copy {
  margin-top: 6rpx;
  color: #7d735f;
  font-size: 24rpx;
  line-height: 1.45;
}

.product-card {
  display: flex;
  gap: 20rpx;
  padding: 26rpx 0;
  border-bottom: 1rpx solid rgba(17, 17, 17, 0.06);
}

.thumb {
  width: 176rpx;
  height: 176rpx;
  flex: 0 0 176rpx;
}

.product-info {
  flex: 1;
  min-width: 0;
}

.product-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.product-title {
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.25;
}

.product-desc {
  display: -webkit-box;
  margin-top: 10rpx;
  overflow: hidden;
  color: #777c75;
  font-size: 24rpx;
  line-height: 1.45;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.product-meta {
  margin-top: 10rpx;
  color: #a0a59d;
  font-size: 22rpx;
}

.product-bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 18rpx;
}

.sku-name {
  margin-top: 4rpx;
  color: #a0a59d;
  font-size: 22rpx;
}

.order-chip {
  width: 112rpx;
  height: 54rpx;
  line-height: 54rpx;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 14rpx;
  background: #d9b073;
  color: #ffffff;
  font-size: 23rpx;
  font-weight: 800;
}

.order-chip::after {
  border: 0;
}
