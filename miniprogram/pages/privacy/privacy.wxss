.page-policy {
  min-height: 100vh;
  background: #f7f8f5;
  padding: 0 30rpx 60rpx;
}
.header {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e8e8e8;
  margin-bottom: 30rpx;
}
.back {
  font-size: 28rpx;
  color: #8b7355;
  margin-right: 20rpx;
  padding: 10rpx;
}
.title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}
.update-date {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 30rpx;
  text-align: center;
}
.section {
  margin-bottom: 36rpx;
}
.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}
.para {
  display: block;
  font-size: 26rpx;
  color: #555;
  line-height: 1.7;
  margin-bottom: 10rpx;
}
