.page { padding: 0 30rpx; min-height: 100vh; background: #f5f5f5; }
.page-header { display: flex; align-items: center; gap: 16rpx; padding: 30rpx 0; }
.back { font-size: 28rpx; color: #2f54a0; }
.page-title { flex: 1; font-size: 32rpx; font-weight: 600; color: #333; }
.header-btn { font-size: 26rpx; color: #2f54a0; font-weight: 600; padding: 8rpx 16rpx; }
.loading { text-align: center; padding: 60rpx; color: #999; }
.stat-row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12rpx; margin-bottom: 20rpx; }
.s-card { background: #fff; border-radius: 12rpx; padding: 20rpx; text-align: center; font-size: 22rpx; color: #666; }
.s-num { font-size: 40rpx; font-weight: 700; color: #1a1a2e; display: block; }
.benefit-item { display: flex; justify-content: space-between; align-items: center; background: #fff; padding: 20rpx 24rpx; border-radius: 12rpx; margin-bottom: 8rpx; }
.bi-left { flex: 1; }
.bi-title { font-size: 26rpx; font-weight: 600; color: #333; display: block; }
.bi-tier { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }
.bi-date { font-size: 20rpx; color: #ccc; display: block; }
.bi-status { font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 20rpx; }
.bi-status.active { background: #e8f5e9; color: #2e7d32; }
.bi-status.used { background: #f5f5f5; color: #999; }
.empty { text-align: center; padding: 80rpx; color: #999; font-size: 24rpx; }
