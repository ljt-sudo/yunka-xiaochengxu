<view class="page safe-bottom" wx:if="{{user && user.isAdmin}}">
  <view class="header">
    <text class="header-title">商家后台</text>
    <text class="header-sub">云咖铺子 · 运营管理中心</text>
  </view>

  <!-- 快捷统计 -->
  <view class="stat-row" wx:if="{{stats}}">
    <view class="stat-card"><text class="stat-num">{{stats.products||0}}</text><text>商品</text></view>
    <view class="stat-card"><text class="stat-num">{{stats.orders||0}}</text><text>订单</text></view>
    <view class="stat-card"><text class="stat-num">{{stats.members||0}}</text><text>会员</text></view>
    <view class="stat-card"><text class="stat-num">{{stats.coupons||0}}</text><text>优惠券</text></view>
  </view>

  <!-- 商品管理 -->
  <view class="section-title"><text>📦 商品管理</text></view>
  <view class="card-grid">
    <view class="card" data-url="/pages/admin/products/products" bindtap="go">
      <text class="card-icon">📋</text>
      <text class="card-title">商品与库存</text>
      <text class="card-desc">上架、下架、价格和库存管理</text>
    </view>
  </view>

  <!-- 订单管理 -->
  <view class="section-title"><text>📋 订单管理</text></view>
  <view class="card-grid">
    <view class="card" data-url="/pages/admin/orders/orders" bindtap="go">
      <text class="card-icon">🚚</text>
      <text class="card-title">订单发货</text>
      <text class="card-desc">查看订单、录入快递单号</text>
    </view>
  </view>

  <!-- 会员管理 -->
  <view class="section-title"><text>👤 会员管理</text></view>
  <view class="card-grid">
    <view class="card" data-url="/pages/admin/members/members" bindtap="go">
      <text class="card-icon">👥</text>
      <text class="card-title">会员列表</text>
      <text class="card-desc">查询会员、查看积分、调整等级</text>
    </view>
    <view class="card" data-url="/pages/admin/tiers/tiers" bindtap="go">
      <text class="card-icon">🏅</text>
      <text class="card-title">等级配置</text>
      <text class="card-desc">编辑会员等级、权益和升级门槛</text>
    </view>
    <view class="card" data-url="/pages/admin/benefits/benefits" bindtap="go">
      <text class="card-icon">🎁</text>
      <text class="card-title">权益管理</text>
      <text class="card-desc">发放权益、查看发放记录</text>
    </view>
  </view>

  <!-- 营销管理 -->
  <view class="section-title"><text>🎯 营销管理</text></view>
  <view class="card-grid">
    <view class="card" data-url="/pages/admin/coupons/coupons" bindtap="go">
      <text class="card-icon">🎫</text>
      <text class="card-title">优惠券</text>
      <text class="card-desc">创建和管理发券活动</text>
    </view>
    <view class="card" data-url="/pages/admin/subscribe/subscribe" bindtap="go">
      <text class="card-icon">🔔</text>
      <text class="card-title">订阅唤醒</text>
      <text class="card-desc">复购提醒和券到账推送</text>
    </view>
  </view>

  <!-- 系统设置 -->
  <view class="section-title"><text>⚙️ 系统设置</text></view>
  <view class="card-grid">
    <view class="card" data-url="/pages/admin/settings/settings" bindtap="go">
      <text class="card-icon">🔧</text>
      <text class="card-title">基础设置</text>
      <text class="card-desc">积分规则、运费配置、门店信息</text>
    </view>
  </view>
</view>

<!-- 无权限 -->
<view class="page" wx:else>
  <view class="no-auth" wx:if="{{!loading}}">
    <text class="no-auth-icon">🔒</text>
    <text class="no-auth-text">无后台权限</text>
    <text class="no-auth-desc">请在 admin_users 白名单中配置管理员</text>
  </view>
</view>
