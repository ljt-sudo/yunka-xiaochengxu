.page { padding: 0 30rpx; min-height: 100vh; background: #f5f5f5; }
.page-header { display: flex; align-items: center; gap: 16rpx; padding: 30rpx 0; }
.back { font-size: 28rpx; color: #2f54a0; }
.page-title { font-size: 32rpx; font-weight: 600; color: #333; }
.search { width: 100%; padding: 20rpx 24rpx; background: #fff; border-radius: 12rpx; font-size: 26rpx; margin-bottom: 20rpx; }
.loading { text-align: center; padding: 60rpx; color: #999; font-size: 26rpx; }

.detail-card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx; }
.detail-row { display: flex; justify-content: space-between; padding: 12rpx 0; font-size: 26rpx; border-bottom: 2rpx solid #f5f5f5; }
.detail-row:last-child { border: none; }
.detail-row .label { color: #999; }
.detail-row .points { font-weight: 700; color: #e67e22; }
.detail-btns { display: flex; gap: 16rpx; margin-top: 16rpx; }
.btn-sm { flex: 1; padding: 16rpx; background: #2f2118; color: #fff; border-radius: 8rpx; font-size: 24rpx; text-align: center; }
.btn-outline { background: #fff; border: 2rpx solid #2f2118; color: #2f2118; }
.tier-tag { display: inline-block; padding: 4rpx 14rpx; border-radius: 20rpx; font-size: 22rpx; background: #f0e6d3; color: #2f2118; }
.tier-tag.sm { font-size: 20rpx; }
.section-title { font-size: 26rpx; font-weight: 600; color: #333; margin-bottom: 12rpx; }
.member-item {
  display: flex; justify-content: space-between; align-items: center;
  background: #fff; padding: 20rpx 24rpx; border-radius: 12rpx; margin-bottom: 8rpx; box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.03);
}
.member-name { font-size: 26rpx; font-weight: 600; color: #333; }
.member-info { display: flex; align-items: center; gap: 12rpx; }
.member-points { font-size: 24rpx; color: #999; }
