.page { padding: 0 30rpx; min-height: 100vh; background: #f5f5f5; padding-bottom: 60rpx; }
.page-header { display: flex; align-items: center; gap: 16rpx; padding: 30rpx 0; }
.back { font-size: 28rpx; color: #2f54a0; }
.page-title { flex: 1; font-size: 32rpx; font-weight: 600; color: #333; }
.header-btn { font-size: 26rpx; color: #2f54a0; font-weight: 600; }
.loading { text-align: center; padding: 60rpx; color: #999; }
.section { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; }
.s-title { font-size: 26rpx; font-weight: 600; margin-bottom: 16rpx; display: block; }
.field { display: block; margin-bottom: 14rpx; }
.field text { font-size: 22rpx; color: #999; display: block; margin-bottom: 6rpx; }
.field input { width: 100%; padding: 14rpx; border: 2rpx solid #eee; border-radius: 8rpx; font-size: 24rpx; box-sizing: border-box; }
