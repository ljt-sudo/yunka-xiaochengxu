.page { padding: 0 30rpx; min-height: 100vh; background: #f7f8f5; }
.header { display: flex; align-items: center; gap: 16rpx; padding: 30rpx 0; }
.back { font-size: 36rpx; color: #333; padding: 8rpx; }
.title { font-size: 32rpx; font-weight: 600; color: #333; }
.loading-center { text-align: center; padding: 80rpx 0; color: #999; font-size: 26rpx; }
.item {
  display: flex; justify-content: space-between; align-items: center;
  background: #fff; padding: 24rpx; border-radius: 12rpx; margin-bottom: 8rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.03);
}
.item-left { flex: 1; margin-right: 16rpx; }
.item-remark { font-size: 26rpx; color: #333; display: block; }
.item-date { font-size: 22rpx; display: block; margin-top: 4rpx; }
.item-amt { font-size: 32rpx; font-weight: 700; }
.item-amt.earn { color: #4CAF50; }
.item-amt.redeem { color: #ff4757; }
.muted { color: #999; }
.loading-more, .no-more { text-align: center; padding: 30rpx; color: #999; font-size: 24rpx; }
