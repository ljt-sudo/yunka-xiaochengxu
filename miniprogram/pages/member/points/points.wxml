<view class="page">
  <view class="header">
    <view class="back" bindtap="wx.navigateBack">←</view>
    <text class="title">积分明细</text>
  </view>

  <view class="loading-center" wx:if="{{loading && list.length === 0}}">加载中...</view>

  <view class="list" wx:else>
    <view class="item" wx:for="{{list}}" wx:key="_id">
      <view class="item-left">
        <text class="item-remark">{{item.remark || item.source}}</text>
        <text class="item-date muted">{{dateText(item.createdAt)}}</text>
      </view>
      <text class="item-amt {{item.amount > 0 ? 'earn' : 'redeem'}}">
        {{item.amount > 0 ? '+' : ''}}{{item.amount}}
      </text>
    </view>

    <view class="loading-more" wx:if="{{loading}}">加载更多...</view>
    <view class="no-more" wx:elif="{{!hasMore}}">— 没有更多了 —</view>
  </view>
</view>
