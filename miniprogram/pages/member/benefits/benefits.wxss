.page { padding: 0 30rpx; min-height: 100vh; background: #f7f8f5; }
.header { display: flex; align-items: center; gap: 16rpx; padding: 30rpx 0; }
.back { font-size: 36rpx; color: #333; padding: 8rpx; }
.title { font-size: 32rpx; font-weight: 600; color: #333; }
.loading-center { text-align: center; padding: 80rpx; color: #999; font-size: 26rpx; }
.item {
  display: flex; justify-content: space-between; align-items: center;
  background: #fff; padding: 24rpx; border-radius: 16rpx; margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.item:active { background: #f5f5f5; }
.item-left { flex: 1; margin-right: 16rpx; }
.item-title { font-size: 26rpx; font-weight: 600; color: #333; display: block; }
.item-desc { font-size: 22rpx; color: #666; display: block; margin-top: 4rpx; }
.item-date { font-size: 20rpx; display: block; margin-top: 4rpx; }
.item-btn {
  padding: 12rpx 28rpx; background: #2f2118; color: #fff; border-radius: 30rpx;
  font-size: 24rpx; font-weight: 600; flex-shrink: 0;
}
.item-btn:active { opacity: 0.8; }
.muted { color: #999; }
.empty { text-align: center; padding: 80rpx; color: #999; font-size: 24rpx; }
