page {
  min-height: 100%;
  background: #f7f8f5;
  color: #111111;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Arial, sans-serif;
}

.page {
  min-height: 100vh;
  padding: 28rpx 24rpx;
  box-sizing: border-box;
}

.section {
  margin-top: 32rpx;
}

.card {
  background: #ffffff;
  border: 1rpx solid rgba(17, 17, 17, 0.06);
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 10rpx 30rpx rgba(17, 17, 17, 0.04);
}

.muted {
  color: #777c75;
  font-size: 26rpx;
  line-height: 1.55;
}

.title {
  font-size: 46rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.h2 {
  font-size: 32rpx;
  font-weight: 800;
  margin-bottom: 14rpx;
}

.row {
  display: flex;
  align-items: center;
}

.between {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.btn {
  border-radius: 16rpx;
  background: #111111;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 76rpx;
  height: 76rpx;
  padding: 0 34rpx;
  border: 0;
  margin: 0;
}

.btn::after {
  border: 0;
}

.btn.secondary {
  background: #e8f3e8;
  color: #174b2b;
}

.btn.ghost {
  background: transparent;
  color: #111111;
  border: 1rpx solid rgba(17, 17, 17, 0.12);
}

.price {
  color: #111111;
  font-weight: 800;
}

.pill {
  display: inline-flex;
  align-items: center;
  border-radius: 10rpx;
  padding: 7rpx 16rpx;
  background: #f0f4ef;
  color: #31543c;
  font-size: 22rpx;
}

.grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.product-image,
.hero-image {
  width: 100%;
  display: block;
  border-radius: 16rpx;
  background: #eef0eb;
}

.product-card {
  overflow: hidden;
}

.product-card .body {
  padding-top: 18rpx;
}

.input,
.textarea {
  width: 100%;
  box-sizing: border-box;
  background: #fffaf2;
  border: 1rpx solid rgba(47, 33, 24, 0.14);
  border-radius: 12rpx;
  padding: 18rpx;
  font-size: 28rpx;
  color: #2f2118;
}

.textarea {
  min-height: 140rpx;
}

.list-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(47, 33, 24, 0.08);
}

.list-item:last-child {
  border-bottom: 0;
}

.safe-bottom {
  padding-bottom: calc(28rpx + env(safe-area-inset-bottom));
}
