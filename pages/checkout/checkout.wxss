.field {
  margin-top: 16rpx;
}

.coupon-option {
  border: 1rpx solid rgba(47, 33, 24, 0.12);
  border-radius: 14rpx;
  padding: 20rpx;
  margin-top: 14rpx;
}

.coupon-option.active {
  border-color: #7a351f;
  background: #f7eadc;
}

.points-input {
  width: 190rpx;
  text-align: right;
}

.total {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(47, 33, 24, 0.1);
  font-weight: 700;
}

.checkout-btn {
  margin-top: 28rpx;
}
