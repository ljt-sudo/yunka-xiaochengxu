<wxs src="../../common/format.wxs" module="fmt" />
<view class="page safe-bottom">
  <view class="title">确认订单</view>
  <view class="muted">支付、积分和优惠券都会由服务端重新计算。</view>

  <view class="section card">
    <view class="h2">收货信息</view>
    <input class="input" data-field="name" bindinput="inputAddress" value="{{address.name}}" placeholder="收货人" />
    <input class="input field" data-field="phone" bindinput="inputAddress" value="{{address.phone}}" placeholder="手机号" />
    <textarea class="textarea field" data-field="detail" bindinput="inputAddress" value="{{address.detail}}" placeholder="详细地址"></textarea>
  </view>

  <view class="section card">
    <view class="h2">商品</view>
    <view class="list-item" wx:for="{{items}}" wx:key="id">
      <view class="between">
        <view>
          <view>{{item.product.title}}</view>
          <view class="muted">{{item.sku.name}} × {{item.quantity}}</view>
        </view>
        <view class="price">{{fmt.money(item.subtotalCents)}}</view>
      </view>
    </view>
  </view>

  <view class="section card">
    <view class="h2">优惠券</view>
    <view class="coupon-option {{selectedCouponClaimId === item.id ? 'active' : ''}}" wx:for="{{couponClaims}}" wx:key="id" data-id="{{item.id}}" bindtap="chooseCoupon">
      <view class="between">
        <view>{{item.coupon.title}}</view>
        <view class="price">-{{fmt.money(item.coupon.amountOffCents)}}</view>
      </view>
      <view class="muted">满 {{fmt.money(item.coupon.minSpendCents)}} 可用</view>
    </view>
    <view class="muted" wx:if="{{couponClaims.length === 0}}">暂无可用优惠券</view>
  </view>

  <view class="section card">
    <view class="between">
      <view>
        <view class="h2">积分抵现</view>
        <view class="muted">50 积分抵 1 元，最多抵商品金额 20%</view>
      </view>
      <input class="input points-input" type="number" bindinput="inputPoints" value="{{requestedPoints}}" />
    </view>
  </view>

  <view class="section card" wx:if="{{totals}}">
    <view class="between"><view>商品金额</view><view>{{fmt.money(totals.goodsAmountCents)}}</view></view>
    <view class="between"><view>运费</view><view>{{fmt.money(totals.shippingFeeCents)}}</view></view>
    <view class="between"><view>优惠券</view><view>-{{fmt.money(totals.couponDiscountCents)}}</view></view>
    <view class="between"><view>积分抵扣</view><view>-{{fmt.money(totals.pointsDiscountCents)}} / {{totals.pointsUsed}} 积分</view></view>
    <view class="between total"><view>应付</view><view class="price">{{fmt.money(totals.payableAmountCents)}}</view></view>
    <view class="muted">支付成功后预计获得 {{totals.earnPoints}} 积分</view>
  </view>

  <view class="section card" wx:if="{{error}}">
    <view class="muted">{{error}}</view>
  </view>

  <button class="btn checkout-btn" bindtap="createOrder" disabled="{{!totals}}">提交订单</button>
</view>
