<wxs src="../../common/format.wxs" module="fmt" />
<view class="page safe-bottom" wx:if="{{user}}">
  <view class="card member-card">
    <view class="pill">会员中心</view>
    <view class="title">{{user.nickname}}</view>
    <view class="points">{{user.pointsBalance}}</view>
    <view class="muted">当前积分 · {{settings.points.redeemText}}</view>
  </view>

  <view class="section grid-actions">
    <button class="btn secondary" bindtap="goOrders">我的订单</button>
    <button class="btn secondary" bindtap="goCoupons">优惠券</button>
    <button class="btn secondary" bindtap="requestSubscribe">订阅提醒</button>
    <button class="btn secondary" bindtap="goSupport">售后客服</button>
  </view>

  <view class="section card">
    <view class="between">
      <view class="h2">积分流水</view>
      <view class="muted">{{settings.points.earnText}}</view>
    </view>
    <view class="list-item" wx:for="{{pointsLedger}}" wx:key="id">
      <view class="between">
        <view>
          <view>{{item.type}}</view>
          <view class="muted">{{fmt.dateText(item.createdAt)}} {{item.note || ''}}</view>
        </view>
        <view class="price">{{item.points > 0 ? '+' : ''}}{{item.points}}</view>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{user.isAdmin}}">
    <button class="btn" bindtap="goAdmin">进入商家后台</button>
    <button class="btn ghost reset" bindtap="resetDemo">重置体验数据</button>
  </view>
</view>
