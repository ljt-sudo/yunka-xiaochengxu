.member-card {
  background: #2f2118;
  color: #fffaf2;
}

.member-card .muted {
  color: rgba(255, 250, 242, 0.72);
}

.points {
  font-size: 72rpx;
  font-weight: 700;
  margin-top: 28rpx;
}

.grid-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.reset {
  margin-top: 18rpx;
}
