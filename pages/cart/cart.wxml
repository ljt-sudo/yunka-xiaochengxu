<wxs src="../../common/format.wxs" module="fmt" />
<view class="page safe-bottom">
  <view class="title">购物车</view>
  <view class="muted">库存、积分、优惠券会在结算页重新校验。</view>

  <view class="section card" wx:if="{{items.length === 0}}">
    <view class="h2">还没有商品</view>
    <view class="muted">去商品页挑一杯云咖吧。</view>
  </view>

  <view class="section card" wx:for="{{items}}" wx:key="id">
    <view class="row cart-row">
      <image class="product-image thumb" mode="aspectFill" src="{{item.product.cover}}"></image>
      <view class="cart-info">
        <view class="h2">{{item.product.title}}</view>
        <view class="muted">{{item.sku.name}}</view>
        <view class="between">
          <view class="price">{{fmt.money(item.subtotalCents)}}</view>
          <view class="row">
            <button class="btn ghost small" data-id="{{item.id}}" data-delta="-1" bindtap="step">-</button>
            <view class="qty">{{item.quantity}}</view>
            <button class="btn ghost small" data-id="{{item.id}}" data-delta="1" bindtap="step">+</button>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="cart-footer">
    <view>
      <view class="muted">商品合计</view>
      <view class="price">{{fmt.money(goodsAmountCents)}}</view>
    </view>
    <button class="btn" bindtap="checkout">去结算</button>
  </view>
</view>
