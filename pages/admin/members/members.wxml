<wxs src="../../../common/format.wxs" module="fmt" />
<view class="page safe-bottom" wx:if="{{user}}">
  <view class="title">会员积分</view>
  <view class="muted">当前只做单管理员、单体验会员；接云开发后按 openid 查询。</view>

  <view class="section card">
    <view class="between">
      <view>
        <view class="h2">{{user.nickname}}</view>
        <view class="muted">积分余额</view>
      </view>
      <view class="points">{{user.pointsBalance}}</view>
    </view>
  </view>

  <view class="section card">
    <view class="h2">人工调整</view>
    <input class="input" type="number" data-field="points" value="{{points}}" bindinput="input" placeholder="积分，可填负数" />
    <input class="input field" data-field="note" value="{{note}}" bindinput="input" placeholder="备注" />
    <button class="btn" bindtap="adjust">保存调整</button>
  </view>

  <view class="section card">
    <view class="h2">流水</view>
    <view class="list-item" wx:for="{{pointsLedger}}" wx:key="id">
      <view class="between">
        <view>
          <view>{{item.type}}</view>
          <view class="muted">{{fmt.dateText(item.createdAt)}} {{item.note || ''}}</view>
        </view>
        <view class="price">{{item.points > 0 ? '+' : ''}}{{item.points}}</view>
      </view>
    </view>
  </view>
</view>
